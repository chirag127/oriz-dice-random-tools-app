---
import '~/styles/global.css'
import { pricingUrl } from '@chirag127/astro-shell/pricing-url'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz Random — Cryptographically random. Tactile and weird.', description = 'Random numbers, dice, passwords, UUIDs, coin flips, shuffles, lottery, name picker, colours.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://random.oriz.in').toString()
const pricingHref = pricingUrl('oriz-dice-random-tools-app')
const signInHref = 'https://account.oriz.in/sign-in?return=https://random.oriz.in/'
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">Random</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href={pricingHref}>pricing</a>
        <a href={signInHref}>sign in</a>
      </nav>
    </header>
    <div class="oriz-shell">
      <FamilySidebar slug="oriz-dice-random-tools-app" title="Random Tools">
        <a slot="tools" href="/tools/coin/">Coin flip</a>
        <a slot="tools" href="/tools/color/">Color picker</a>
        <a slot="tools" href="/tools/dice/">Dice roller</a>
        <a slot="tools" href="/tools/lottery/">Lottery numbers</a>
        <a slot="tools" href="/tools/name/">Name picker</a>
        <a slot="tools" href="/tools/number/">Random number</a>
        <a slot="tools" href="/tools/password/">Password</a>
        <a slot="tools" href="/tools/shuffle/">Shuffle list</a>
        <a slot="tools" href="/tools/uuid/">UUID v4</a>
      </FamilySidebar>
      <main id="main" class="oriz-main"><slot /></main>
    </div>
    <footer class="site">
      <span>Oriz Random · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
  </body>
</html>
