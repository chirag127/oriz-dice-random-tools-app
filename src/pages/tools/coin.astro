---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Coin Flip — Oriz Random" description="Flip a virtual coin. Cryptographically fair heads or tails with flip animation. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">coin flip</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="lede">Cryptographically fair flip. Uses <code>crypto.getRandomValues</code>.</p>

    <div class="tool-body">
      <div class="coin-wrap">
        <div id="coin" class="coin" aria-hidden="true">
          <div class="face heads">H</div>
          <div class="face tails">T</div>
        </div>
      </div>
      <button id="flip-btn" class="btn primary">Flip</button>

      <div id="result-area" class="result-area hidden" aria-live="polite">
        <span id="result-text" class="result-text mono"></span>
        <button id="copy-btn" class="btn secondary small">Copy</button>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .lede code { background: var(--paper-2); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.85em; }
  .tool-body { max-width: 32rem; }
  .coin-wrap { margin-bottom: 1.5rem; }
  .coin {
    width: 5rem; height: 5rem;
    perspective: 600px;
    display: inline-block;
  }
  .coin-inner {
    width: 100%; height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s ease-in-out;
  }
  .face {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    font-family: var(--font-mono); font-weight: 700; font-size: 1.5rem;
    backface-visibility: hidden;
  }
  .heads { background: var(--accent); color: var(--paper); }
  .tails { background: var(--paper-2); color: var(--ink); border: 2px solid var(--rule); transform: rotateY(180deg); }
  @keyframes flip-anim {
    0%   { transform: rotateY(0deg); }
    100% { transform: rotateY(var(--end-deg, 720deg)); }
  }
  .coin.flipping .coin-inner { animation: flip-anim 0.7s ease-in-out forwards; }

  .btn {
    padding: 0.6rem 1.25rem; font-size: 0.875rem; font-weight: 600;
    border: none; cursor: pointer; transition: opacity 100ms;
  }
  .btn:hover { opacity: 0.85; }
  .btn:active { opacity: 0.7; }
  .btn.primary { background: var(--accent); color: var(--paper); }
  .btn.secondary { background: var(--paper-2); color: var(--ink); border: 1px solid var(--rule); }
  .btn.small { font-size: 0.75rem; padding: 0.4rem 0.85rem; margin-left: 1rem; }
  .result-area { display: flex; align-items: center; margin-top: 1.5rem; padding: 1rem 1.25rem; background: var(--paper-2); border: 1px solid var(--rule); }
  .result-area.hidden { display: none; }
  .result-text { font-size: 1.5rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
</style>

<script>
  let isFlipping = false;

  function flip() {
    if (isFlipping) return;
    const coin = document.getElementById('coin')!;
    const resultArea = document.getElementById('result-area')!;
    const resultText = document.getElementById('result-text')!;

    const arr = new Uint8Array(1);
    crypto.getRandomValues(arr);
    const isHeads = arr[0] % 2 === 0;

    // Build inner if not already
    let inner = coin.querySelector('.coin-inner') as HTMLElement | null;
    if (!inner) {
      inner = document.createElement('div');
      inner.className = 'coin-inner';
      const headsEl = coin.querySelector('.heads')!;
      const tailsEl = coin.querySelector('.tails')!;
      inner.appendChild(headsEl);
      inner.appendChild(tailsEl);
      coin.appendChild(inner);
    }

    const spins = 3;
    const endDeg = isHeads ? spins * 360 : spins * 360 + 180;
    inner.style.setProperty('--end-deg', `${endDeg}deg`);
    inner.style.animation = 'none';
    void inner.offsetHeight;
    inner.style.animation = '';

    coin.classList.add('flipping');
    isFlipping = true;

    setTimeout(() => {
      coin.classList.remove('flipping');
      isFlipping = false;
      resultText.textContent = isHeads ? 'Heads' : 'Tails';
      resultArea.classList.remove('hidden');
    }, 750);
  }

  document.getElementById('flip-btn')!.addEventListener('click', flip);
  document.getElementById('copy-btn')!.addEventListener('click', async () => {
    const val = document.getElementById('result-text')!.textContent ?? '';
    await navigator.clipboard.writeText(val);
    const btn = document.getElementById('copy-btn') as HTMLButtonElement;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 1200);
  });
</script>
