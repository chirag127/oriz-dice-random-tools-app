---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Dice Roller (3d6+2 notation) — Oriz Random" description="Roll any dice expression like 4d6+2. Cryptographically random. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">dice roller</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="lede">Enter a notation like <code>3d6</code>, <code>2d10+4</code>, or <code>d20</code>. Uses <code>crypto.getRandomValues</code>.</p>

    <div class="tool-body">
      <div class="row">
        <input id="notation" class="input mono" type="text" value="3d6" placeholder="3d6+2" spellcheck="false" autocomplete="off" />
        <button id="roll-btn" class="btn primary">Roll</button>
      </div>
      <div id="result-area" class="result-area hidden" aria-live="polite">
        <div id="dice-display" class="dice-display"></div>
        <div class="result-line">
          <span class="result-label mono">total</span>
          <span id="total" class="result-value mono"></span>
        </div>
        <div class="result-line">
          <span class="result-label mono">breakdown</span>
          <span id="breakdown" class="result-detail mono"></span>
        </div>
        <button id="copy-btn" class="btn secondary small">Copy result</button>
      </div>
      <p id="error-msg" class="error-msg hidden mono" role="alert"></p>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .lede code { background: var(--paper-2); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.85em; }
  .tool-body { max-width: 32rem; }
  .row { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
  .input {
    flex: 1; padding: 0.6rem 0.75rem;
    background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 1rem;
  }
  .input:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
  .btn {
    padding: 0.6rem 1.25rem; font-size: 0.875rem; font-weight: 600;
    border: none; cursor: pointer; transition: opacity 100ms;
  }
  .btn:hover { opacity: 0.85; }
  .btn:active { opacity: 0.7; }
  .btn.primary { background: var(--accent); color: var(--paper); }
  .btn.secondary { background: var(--paper-2); color: var(--ink); border: 1px solid var(--rule); }
  .btn.small { font-size: 0.75rem; padding: 0.4rem 0.85rem; margin-top: 0.75rem; }
  .result-area { margin-top: 0.5rem; padding: 1rem 1.25rem; background: var(--paper-2); border: 1px solid var(--rule); }
  .result-area.hidden { display: none; }
  .dice-display { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .die {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.5rem; height: 2.5rem; background: var(--paper);
    border: 2px solid var(--accent); border-radius: 6px;
    font-family: var(--font-mono); font-weight: 700; font-size: 1.1rem;
    color: var(--accent);
    animation: pop 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes pop { from { transform: scale(0.5) rotate(-15deg); opacity: 0; } to { transform: scale(1) rotate(0deg); opacity: 1; } }
  .result-line { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.375rem; }
  .result-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; min-width: 8ch; }
  .result-value { font-size: 2rem; font-weight: 700; color: var(--ink); line-height: 1; }
  .result-detail { font-size: 0.875rem; color: var(--muted); }
  .error-msg { font-size: 0.875rem; color: #e05252; margin-top: 0.5rem; }
  .error-msg.hidden { display: none; }
</style>

<script>
  function cryptoRandInt(min: number, max: number): number {
    // [min, max] inclusive
    const range = max - min + 1;
    const arr = new Uint32Array(1);
    let val: number;
    do {
      crypto.getRandomValues(arr);
      val = arr[0];
    } while (val >= Math.floor(0xFFFFFFFF / range) * range);
    return min + (val % range);
  }

  function parseNotation(raw: string): { count: number; sides: number; mod: number } | null {
    const m = raw.trim().toLowerCase().match(/^(\d*)d(\d+)([+-]\d+)?$/);
    if (!m) return null;
    const count = m[1] ? parseInt(m[1]) : 1;
    const sides = parseInt(m[2]);
    const mod = m[3] ? parseInt(m[3]) : 0;
    if (count < 1 || count > 100 || sides < 2 || sides > 1000) return null;
    return { count, sides, mod };
  }

  function roll() {
    const input = document.getElementById('notation') as HTMLInputElement;
    const resultArea = document.getElementById('result-area')!;
    const diceDisplay = document.getElementById('dice-display')!;
    const totalEl = document.getElementById('total')!;
    const breakdownEl = document.getElementById('breakdown')!;
    const errorEl = document.getElementById('error-msg')!;

    const parsed = parseNotation(input.value);
    if (!parsed) {
      resultArea.classList.add('hidden');
      errorEl.textContent = 'Invalid notation. Try: 3d6, 2d10+4, d20';
      errorEl.classList.remove('hidden');
      return;
    }
    errorEl.classList.add('hidden');

    const { count, sides, mod } = parsed;
    const rolls: number[] = [];
    for (let i = 0; i < count; i++) rolls.push(cryptoRandInt(1, sides));
    const sum = rolls.reduce((a, b) => a + b, 0) + mod;

    // Rebuild dice display with staggered animation
    diceDisplay.innerHTML = '';
    rolls.forEach((v, i) => {
      const die = document.createElement('span');
      die.className = 'die';
      die.textContent = String(v);
      die.style.animationDelay = `${i * 40}ms`;
      diceDisplay.appendChild(die);
    });

    totalEl.textContent = String(sum);
    const parts = rolls.join(' + ');
    breakdownEl.textContent = mod !== 0
      ? `[${parts}]${mod > 0 ? '+' : ''}${mod} = ${sum}`
      : `[${parts}] = ${sum}`;

    resultArea.classList.remove('hidden');
  }

  document.getElementById('roll-btn')!.addEventListener('click', roll);
  (document.getElementById('notation') as HTMLInputElement).addEventListener('keydown', (e) => {
    if (e.key === 'Enter') roll();
  });
  document.getElementById('copy-btn')!.addEventListener('click', async () => {
    const total = document.getElementById('total')!.textContent ?? '';
    const breakdown = document.getElementById('breakdown')!.textContent ?? '';
    const text = `${total} (${breakdown})`;
    await navigator.clipboard.writeText(text);
    const btn = document.getElementById('copy-btn') as HTMLButtonElement;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 1200);
  });
</script>
