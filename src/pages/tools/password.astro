---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Password Generator — Oriz Random" description="Generate strong cryptographically secure passwords with custom length and character sets. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">password generator</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="lede">Generates passwords using <code>crypto.getRandomValues</code>. Nothing is sent anywhere.</p>

    <div class="tool-body">
      <label class="field" style="max-width:12rem;">
        <span class="field-label mono">length</span>
        <input id="length" class="input mono" type="number" value="20" min="4" max="128" />
      </label>

      <fieldset class="charset-group">
        <legend class="field-label mono">character sets</legend>
        <label class="toggle"><input id="upper" type="checkbox" checked /><span>A–Z uppercase</span></label>
        <label class="toggle"><input id="lower" type="checkbox" checked /><span>a–z lowercase</span></label>
        <label class="toggle"><input id="digits" type="checkbox" checked /><span>0–9 digits</span></label>
        <label class="toggle"><input id="symbols" type="checkbox" checked /><span>!@#$%^&* symbols</span></label>
      </fieldset>

      <button id="generate-btn" class="btn primary">Generate</button>

      <div id="result-area" class="result-area hidden" aria-live="polite">
        <code id="password-output" class="password-out mono"></code>
        <button id="copy-btn" class="btn secondary small">Copy</button>
      </div>
      <p id="error-msg" class="error-msg hidden mono" role="alert"></p>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .lede code { background: var(--paper-2); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.85em; }
  .tool-body { max-width: 32rem; }
  .field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .field-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; }
  .input {
    padding: 0.6rem 0.75rem;
    background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 1rem;
  }
  .input:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
  .charset-group { border: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .toggle { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem; color: var(--muted); }
  .toggle input { width: 1rem; height: 1rem; accent-color: var(--accent); cursor: pointer; }
  .btn {
    padding: 0.6rem 1.25rem; font-size: 0.875rem; font-weight: 600;
    border: none; cursor: pointer; transition: opacity 100ms;
  }
  .btn:hover { opacity: 0.85; }
  .btn:active { opacity: 0.7; }
  .btn.primary { background: var(--accent); color: var(--paper); }
  .btn.secondary { background: var(--paper-2); color: var(--ink); border: 1px solid var(--rule); }
  .btn.small { font-size: 0.75rem; padding: 0.4rem 0.85rem; margin-left: 0.75rem; }
  .result-area { display: flex; align-items: center; margin-top: 1.5rem; padding: 1rem 1.25rem; background: var(--paper-2); border: 1px solid var(--rule); gap: 0.5rem; flex-wrap: wrap; }
  .result-area.hidden { display: none; }
  .password-out { font-size: 0.95rem; word-break: break-all; flex: 1; color: var(--ink); }
  .error-msg { font-size: 0.875rem; color: #e05252; margin-top: 0.5rem; }
  .error-msg.hidden { display: none; }
</style>

<script>
  const UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER = 'abcdefghijklmnopqrstuvwxyz';
  const DIGITS = '0123456789';
  const SYMBOLS = '!@#$%^&*()-_=+[]{}|;:,.<>?';

  function cryptoChoice(alphabet: string): string {
    const arr = new Uint32Array(1);
    do {
      crypto.getRandomValues(arr);
    } while (arr[0] >= Math.floor(0xFFFFFFFF / alphabet.length) * alphabet.length);
    return alphabet[arr[0] % alphabet.length];
  }

  function generate() {
    const length = parseInt((document.getElementById('length') as HTMLInputElement).value);
    const useUpper = (document.getElementById('upper') as HTMLInputElement).checked;
    const useLower = (document.getElementById('lower') as HTMLInputElement).checked;
    const useDigits = (document.getElementById('digits') as HTMLInputElement).checked;
    const useSymbols = (document.getElementById('symbols') as HTMLInputElement).checked;

    const errorEl = document.getElementById('error-msg')!;
    const resultArea = document.getElementById('result-area')!;
    const output = document.getElementById('password-output')!;

    if (!useUpper && !useLower && !useDigits && !useSymbols) {
      errorEl.textContent = 'Select at least one character set.';
      errorEl.classList.remove('hidden');
      resultArea.classList.add('hidden');
      return;
    }
    if (length < 4 || length > 128) {
      errorEl.textContent = 'Length must be between 4 and 128.';
      errorEl.classList.remove('hidden');
      resultArea.classList.add('hidden');
      return;
    }
    errorEl.classList.add('hidden');

    let charset = '';
    const required: string[] = [];
    if (useUpper)  { charset += UPPER;   required.push(cryptoChoice(UPPER)); }
    if (useLower)  { charset += LOWER;   required.push(cryptoChoice(LOWER)); }
    if (useDigits) { charset += DIGITS;  required.push(cryptoChoice(DIGITS)); }
    if (useSymbols){ charset += SYMBOLS; required.push(cryptoChoice(SYMBOLS)); }

    const chars: string[] = required.slice();
    for (let i = chars.length; i < length; i++) {
      chars.push(cryptoChoice(charset));
    }

    // Crypto shuffle (Fisher-Yates)
    for (let i = chars.length - 1; i > 0; i--) {
      const arr = new Uint32Array(1);
      crypto.getRandomValues(arr);
      const j = arr[0] % (i + 1);
      [chars[i], chars[j]] = [chars[j], chars[i]];
    }

    output.textContent = chars.join('');
    resultArea.classList.remove('hidden');
  }

  document.getElementById('generate-btn')!.addEventListener('click', generate);
  document.getElementById('copy-btn')!.addEventListener('click', async () => {
    const val = document.getElementById('password-output')!.textContent ?? '';
    await navigator.clipboard.writeText(val);
    const btn = document.getElementById('copy-btn') as HTMLButtonElement;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 1200);
  });
</script>
