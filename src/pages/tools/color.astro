---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Random Colour Generator — Oriz Random" description="Generate a random colour with hex, RGB, and HSL values. Copy each format. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">random colour</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="lede">Generate a random colour and copy its hex, RGB, or HSL value.</p>

    <div class="tool-body">
      <button id="generate-btn" class="btn primary">Generate</button>

      <div id="result-area" class="result-area hidden" aria-live="polite">
        <div id="swatch" class="swatch"></div>
        <div class="formats">
          <div class="format-row">
            <span class="format-label mono">hex</span>
            <code id="hex-val" class="format-val mono"></code>
            <button class="copy-fmt-btn btn secondary small" data-target="hex-val">Copy</button>
          </div>
          <div class="format-row">
            <span class="format-label mono">rgb</span>
            <code id="rgb-val" class="format-val mono"></code>
            <button class="copy-fmt-btn btn secondary small" data-target="rgb-val">Copy</button>
          </div>
          <div class="format-row">
            <span class="format-label mono">hsl</span>
            <code id="hsl-val" class="format-val mono"></code>
            <button class="copy-fmt-btn btn secondary small" data-target="hsl-val">Copy</button>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .tool-body { max-width: 32rem; }
  .btn {
    padding: 0.6rem 1.25rem; font-size: 0.875rem; font-weight: 600;
    border: none; cursor: pointer; transition: opacity 100ms;
  }
  .btn:hover { opacity: 0.85; }
  .btn:active { opacity: 0.7; }
  .btn.primary { background: var(--accent); color: var(--paper); }
  .btn.secondary { background: var(--paper-2); color: var(--ink); border: 1px solid var(--rule); }
  .btn.small { font-size: 0.75rem; padding: 0.4rem 0.85rem; }
  .result-area { margin-top: 1.5rem; }
  .result-area.hidden { display: none; }
  .swatch {
    width: 100%; height: 8rem;
    border: 1px solid var(--rule);
    border-radius: 4px;
    margin-bottom: 1rem;
    transition: background-color 0.3s ease;
    animation: fade-in 0.25s ease-out;
  }
  @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
  .formats { display: flex; flex-direction: column; gap: 0.5rem; }
  .format-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); }
  .format-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; min-width: 3ch; }
  .format-val { flex: 1; font-size: 0.875rem; color: var(--ink); }
</style>

<script>
  function rgbToHsl(r: number, g: number, b: number): [number, number, number] {
    const rn = r / 255, gn = g / 255, bn = b / 255;
    const max = Math.max(rn, gn, bn), min = Math.min(rn, gn, bn);
    const l = (max + min) / 2;
    if (max === min) return [0, 0, Math.round(l * 100)];
    const d = max - min;
    const s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
    let h: number;
    if (max === rn)      h = ((gn - bn) / d + (gn < bn ? 6 : 0)) / 6;
    else if (max === gn) h = ((bn - rn) / d + 2) / 6;
    else                 h = ((rn - gn) / d + 4) / 6;
    return [Math.round(h * 360), Math.round(s * 100), Math.round(l * 100)];
  }

  function generate() {
    const bytes = new Uint8Array(3);
    crypto.getRandomValues(bytes);
    const [r, g, b] = bytes;

    const hex = `#${r.toString(16).padStart(2, '0')}${g.toString(16).padStart(2, '0')}${b.toString(16).padStart(2, '0')}`;
    const rgb = `rgb(${r}, ${g}, ${b})`;
    const [h, s, l] = rgbToHsl(r, g, b);
    const hsl = `hsl(${h}, ${s}%, ${l}%)`;

    const swatch = document.getElementById('swatch')!;
    swatch.style.animation = 'none';
    void (swatch as HTMLElement).offsetHeight;
    swatch.style.animation = '';
    swatch.style.backgroundColor = hex;

    document.getElementById('hex-val')!.textContent = hex;
    document.getElementById('rgb-val')!.textContent = rgb;
    document.getElementById('hsl-val')!.textContent = hsl;

    document.getElementById('result-area')!.classList.remove('hidden');
  }

  document.getElementById('generate-btn')!.addEventListener('click', generate);
  document.querySelectorAll('.copy-fmt-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = (e.currentTarget as HTMLElement).dataset.target!;
      const val = document.getElementById(target)!.textContent ?? '';
      await navigator.clipboard.writeText(val);
      const b = e.currentTarget as HTMLButtonElement;
      const orig = b.textContent;
      b.textContent = 'Copied!';
      setTimeout(() => { b.textContent = orig; }, 1200);
    });
  });
</script>
