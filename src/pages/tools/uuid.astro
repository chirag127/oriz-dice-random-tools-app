---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="UUID v4 Generator — Oriz Random" description="Generate RFC-4122 UUID v4 identifiers using crypto.randomUUID(). Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">UUID v4 generator</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="lede">Generates RFC-4122 version 4 UUIDs via <code>crypto.randomUUID()</code>. Generate one or many.</p>

    <div class="tool-body">
      <label class="field" style="max-width:10rem;">
        <span class="field-label mono">count</span>
        <input id="count" class="input mono" type="number" value="1" min="1" max="50" />
      </label>
      <button id="generate-btn" class="btn primary">Generate</button>

      <div id="result-area" class="result-area hidden" aria-live="polite">
        <div id="uuid-list" class="uuid-list mono"></div>
        <button id="copy-btn" class="btn secondary small">Copy all</button>
      </div>
      <p id="error-msg" class="error-msg hidden mono" role="alert"></p>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .lede code { background: var(--paper-2); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.85em; }
  .tool-body { max-width: 36rem; }
  .field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .field-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; }
  .input {
    padding: 0.6rem 0.75rem;
    background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 1rem;
  }
  .input:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
  .btn {
    padding: 0.6rem 1.25rem; font-size: 0.875rem; font-weight: 600;
    border: none; cursor: pointer; transition: opacity 100ms;
  }
  .btn:hover { opacity: 0.85; }
  .btn:active { opacity: 0.7; }
  .btn.primary { background: var(--accent); color: var(--paper); }
  .btn.secondary { background: var(--paper-2); color: var(--ink); border: 1px solid var(--rule); }
  .btn.small { font-size: 0.75rem; padding: 0.4rem 0.85rem; margin-top: 0.75rem; }
  .result-area { margin-top: 1.5rem; padding: 1rem 1.25rem; background: var(--paper-2); border: 1px solid var(--rule); }
  .result-area.hidden { display: none; }
  .uuid-list { display: flex; flex-direction: column; gap: 0.35rem; }
  .uuid-item {
    font-size: 0.875rem; color: var(--ink); padding: 0.25rem 0;
    border-bottom: 1px solid var(--rule);
    animation: fade-in 0.15s ease-out;
  }
  .uuid-item:last-child { border-bottom: none; }
  @keyframes fade-in { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
  .error-msg { font-size: 0.875rem; color: #e05252; margin-top: 0.5rem; }
  .error-msg.hidden { display: none; }
</style>

<script>
  function generate() {
    const countEl = document.getElementById('count') as HTMLInputElement;
    const resultArea = document.getElementById('result-area')!;
    const uuidList = document.getElementById('uuid-list')!;
    const errorEl = document.getElementById('error-msg')!;

    const count = parseInt(countEl.value);
    if (isNaN(count) || count < 1 || count > 50) {
      errorEl.textContent = 'Count must be between 1 and 50.';
      errorEl.classList.remove('hidden');
      resultArea.classList.add('hidden');
      return;
    }
    errorEl.classList.add('hidden');

    uuidList.innerHTML = '';
    for (let i = 0; i < count; i++) {
      const div = document.createElement('div');
      div.className = 'uuid-item';
      div.style.animationDelay = `${i * 30}ms`;
      div.textContent = crypto.randomUUID();
      uuidList.appendChild(div);
    }
    resultArea.classList.remove('hidden');
  }

  document.getElementById('generate-btn')!.addEventListener('click', generate);
  document.getElementById('copy-btn')!.addEventListener('click', async () => {
    const items = document.querySelectorAll('.uuid-item');
    const text = Array.from(items).map(el => el.textContent).join('\n');
    await navigator.clipboard.writeText(text);
    const btn = document.getElementById('copy-btn') as HTMLButtonElement;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 1200);
  });
</script>
